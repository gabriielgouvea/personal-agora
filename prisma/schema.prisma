// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  tipo           String   // "aluno" | "personal"
  status         String   @default("ativo") // "pendente" | "ativo" | "suspenso" | "rejeitado"
  nome           String
  sobrenome      String
  email          String   @unique
  senha          String?
  googleId       String?  @unique
  avatarGoogleUrl String?
  telefone       String?  @unique
  isWhatsapp     Boolean  @default(false)
  isTelefone     Boolean  @default(false)
  dataNascimento String?
  sexo           String?
  cpf            String?  @unique
  cep            String?
  rua            String?
  bairro         String?
  cidade         String?
  estado         String?
  numero         String?
  complemento    String?
  esportes       String?  // JSON array
  academias      String?  // JSON array
  temWellhub     Boolean  @default(false)
  temTotalPass   Boolean  @default(false)
  experiencia    String?
  tempoTreino    String?
  avatarUrl      String?

  // PAR-Q (Physical Activity Readiness Questionnaire)
  parqRespostas    String?   // JSON com respostas do PAR-Q
  parqPreenchidoEm DateTime?

  // PCD (Pessoa com Deficiência)
  isPCD            Boolean @default(false)
  tipoDeficiencia  String?

  // Campos específicos de personal
  cref             String?
  validadeCref     String?
  formacao         String?
  rg               String?
  fotoCrefUrl      String?
  selfieUrl        String?
  disponivelEmCasa Boolean @default(false)
  valorAproximado  String?
  tipoChavePix     String?
  chavePix         String?
  // Conta bancária para recebimento de saques
  banco            String?
  agencia          String?
  contaBancaria    String?
  tipoConta        String?  // "corrente" | "poupanca"
  modalidades      String?  // JSON array: ["musculação","funcional",...]
  regioes          String?  // JSON array: ["Alphaville","Tamboré",...]
  preferenciaGeneroAluno String? // "homens" | "mulheres" | "ambos"
  disponibilidade  String?  // JSON: {"seg":["06:00-08:00"],"ter":[],...}
  verificado       Boolean @default(false)

  // Plano
  plano            String?  // "start" | "pro" | "elite"
  planoAtivo       Boolean @default(false)
  planoInicio      DateTime?
  planoFim         DateTime?
  conviteUsado     String?  // código do convite usado

  // Asaas
  asaasCustomerId     String?
  asaasSubscriptionId String?

  // Cupom de desconto na assinatura
  cupomMesesRestantes  Int     @default(0)  // meses de desconto restantes (0 = sem desconto ativo)
  valorPlanoOriginal   Float?               // valor cheio do plano (para restaurar após cupom expirar)

  // Redefinição de senha
  resetToken       String?
  resetTokenExpiry DateTime?

  // Cancelamento de assinatura
  cancelamentoMotivo   String?
  cancelamentoPedidoEm DateTime?

  // Exclusão de conta
  excluirContaMotivo  String?
  contaExcluirEm     DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  aulaComoAluno    Aula[]  @relation("AlunoAulas")
  aulaComoPersonal Aula[]  @relation("PersonalAulas")
  avaliacoesFeitas    Avaliacao[] @relation("AutorAvaliacoes")
  avaliacoesRecebidas Avaliacao[] @relation("AvaliadoAvaliacoes")
  relatosFeitos       Relato[]   @relation("AutorRelatos")
  relatosRecebidos    Relato[]   @relation("RelatadoRelatos")
  saques              Saque[]    @relation("SaquesPersonal")
}

model Aula {
  id              String   @id @default(uuid())
  alunoId         String
  personalId      String
  aluno           User     @relation("AlunoAulas", fields: [alunoId], references: [id])
  personal        User     @relation("PersonalAulas", fields: [personalId], references: [id])
  valor           Float
  // "aguardando_pagamento" | "paga" | "confirmada" | "cancelada" | "reembolsada"
  status          String   @default("aguardando_pagamento")
  formaPagamento  String?  // "PIX" | "CREDIT_CARD" | "BOLETO"
  paidAt          DateTime? // data/hora do pagamento confirmado
  asaasChargeId   String?
  asaasSubscriptionId String?  // assinatura recorrente Asaas
  paymentUrl      String?
  scheduledAt     DateTime?
  confirmedAt     DateTime?  // aluno confirmou a realização da aula
  releasedAt      DateTime?  // pagamento liberado ao personal
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  avaliacoes      Avaliacao[]
  relatos         Relato[]
}

model Avaliacao {
  id              String   @id @default(uuid())
  aulaId          String
  aula            Aula     @relation(fields: [aulaId], references: [id])
  autorId         String
  autor           User     @relation("AutorAvaliacoes", fields: [autorId], references: [id])
  avaliadoId      String
  avaliado        User     @relation("AvaliadoAvaliacoes", fields: [avaliadoId], references: [id])
  nota            Int      // 1 a 5
  comentario      String?
  tipo            String   // "aluno_para_personal" | "personal_para_aluno"
  visivelNoPerfil Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@unique([aulaId, autorId])
}

model Admin {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())
}

model Rede {
  id        String     @id @default(uuid())
  nome      String     @unique
  academias Academia[]
  createdAt DateTime   @default(now())
}

model Academia {
  id        String   @id @default(uuid())
  nome      String
  endereco  String
  redeId    String?
  rede      Rede?    @relation(fields: [redeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Convite {
  id        String   @id @default(uuid())
  codigo    String   @unique
  cpf       String   // CPF de quem pode usar
  usado     Boolean  @default(false)
  usadoPor  String?  // userId de quem usou
  createdAt DateTime @default(now())
}

model Cupom {
  id             String   @id @default(uuid())
  codigo         String   @unique
  tipo           String   // "percentual" | "fixo"
  valor          Float    // ex: 10 (10% ou R$10)
  validade       DateTime?
  limiteUsos     Int      @default(1)
  usosAtuais     Int      @default(0)
  mesesDesconto  Int      @default(0) // 0 = desconto único (compra avulsa), >0 = aplica em N meses de assinatura
  ativo          Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model Relato {
  id            String   @id @default(uuid())
  aulaId        String?
  aula          Aula?    @relation(fields: [aulaId], references: [id])
  autorId       String
  autor         User     @relation("AutorRelatos", fields: [autorId], references: [id])
  relatadoId    String
  relatado      User     @relation("RelatadoRelatos", fields: [relatadoId], references: [id])
  categoria     String
  descricao     String
  status        String   @default("pendente")
  respostaAdmin String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Saque {
  id              String    @id @default(uuid())
  personalId      String
  personal        User      @relation("SaquesPersonal", fields: [personalId], references: [id])
  valor           Float
  destino         String    // "pix" | "banco"
  chavePix        String?
  banco           String?
  agencia         String?
  contaNumero     String?
  tipoConta       String?   // "corrente" | "poupanca"
  status          String    @default("pendente") // "pendente" | "processando" | "pago" | "recusado"
  asaasTransferId String?
  obs             String?
  processadoEm   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
