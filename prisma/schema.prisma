// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model PersonalTrainer {
  id                    String   @id @default(uuid())
  name                  String
  dateOfBirth           DateTime
  gender                String 
  studentGenderPreference String 
  
  academies             String 
  
  residentialAvailable  Boolean
  cref                  String   @unique
  crefValidity          DateTime
  
  whatsapp              String
  email                 String
  instagram             String?
  photoUrl              String?
  contactConsent        Boolean
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model User {
  id             String   @id @default(uuid())
  tipo           String   // "aluno" | "personal"
  status         String   @default("ativo") // "pendente" | "ativo" | "suspenso" | "rejeitado"
  nome           String
  sobrenome      String
  email          String   @unique
  senha          String
  telefone       String   @unique
  isWhatsapp     Boolean  @default(false)
  isTelefone     Boolean  @default(false)
  dataNascimento String?
  sexo           String?
  cpf            String   @unique
  cep            String?
  rua            String?
  bairro         String?
  cidade         String?
  estado         String?
  numero         String?
  complemento    String?
  esportes       String?  // JSON array
  academias      String?  // JSON array
  temWellhub     Boolean  @default(false)
  temTotalPass   Boolean  @default(false)
  experiencia    String?
  tempoTreino    String?
  avatarUrl      String?

  // Campos específicos de personal
  cref             String?
  validadeCref     String?
  formacao         String?
  rg               String?
  fotoCrefUrl      String?
  selfieUrl        String?
  disponivelEmCasa Boolean @default(false)
  valorAproximado  String?
  tipoChavePix     String?
  chavePix         String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Admin {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())
}

model Rede {
  id        String     @id @default(uuid())
  nome      String     @unique
  academias Academia[]
  createdAt DateTime   @default(now())
}

model Academia {
  id        String   @id @default(uuid())
  nome      String
  endereco  String
  redeId    String?
  rede      Rede?    @relation(fields: [redeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
